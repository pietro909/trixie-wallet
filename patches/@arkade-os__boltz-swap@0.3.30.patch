+import { m as SwapRepository, p as BoltzSwapProvider, N as Network } from '../../types-BBI7-KJ0.js';
+import { Identity, ArkProvider, IndexerProvider, IWallet } from '@arkade-os/sdk';
+import { AsyncStorageTaskQueue, TaskProcessor } from '@arkade-os/sdk/worker/expo';
+
+export interface SwapTaskDependencies {
+    swapRepository: SwapRepository;
+    swapProvider: BoltzSwapProvider;
+    arkProvider: ArkProvider;
+    indexerProvider: IndexerProvider;
+    identity: Identity;
+    wallet: IWallet;
+}

+export interface PersistedSwapBackgroundConfig {
+    boltzApiUrl: string;
+    arkServerUrl: string;
+    network: Network;
+}
+
+export interface DefineSwapBackgroundTaskOptions {
+    taskQueue: AsyncStorageTaskQueue;
+    swapRepository: SwapRepository;
+    identityFactory: () => Promise<Identity>;
+}
+
+export declare function defineExpoSwapBackgroundTask(taskName: string, options: DefineSwapBackgroundTaskOptions): void;
+export declare function registerExpoSwapBackgroundTask(taskName: string, options?: {
+    minimumInterval?: number;
+}): Promise<void>;
